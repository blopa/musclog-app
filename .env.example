# Optional: Gemini / OpenAI API keys for AI features
 EXPO_PUBLIC_GEMINI_API_KEY=
 OPENAI_API_KEY=

# Sentry error reporting (optional; if unset, no events are sent)
# Get your DSN from Sentry: Project Settings → Client Keys (DSN)
EXPO_PUBLIC_SENTRY_DSN=

# For EAS Build and prebuild: uploads source maps and debug symbols to Sentry.
# Do not commit this token. Set it in EAS Secrets or CI environment.
 SENTRY_AUTH_TOKEN=
