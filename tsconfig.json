{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "react-native-gifted-chat": ["./types/react-native-gifted-chat.d.ts"]
    },
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },

  "include": [
    "theme.ts",
    "nativewind-env.d.ts",
    "app",
    "components",
    "constants",
    "database",
    "hooks",
    "lang",
    "services",
    "types",
    "utils",
    "widgets"
  ],
  "exclude": ["node_modules", "babel.config.js", "metro.config.js", "tailwind.config.js"]
}
