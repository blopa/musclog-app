{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },

  "include": [
    "app",
    "components",
    "lang",
    "scripts",
    "theme.ts",
    "App.tsx",
    "nativewind-env.d.ts",
    "database",
    "hooks",
    "utils",
    "constants",
    "types"
  ],
  "exclude": ["node_modules", "babel.config.js", "metro.config.js", "tailwind.config.js"]
}
