{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "react-native-gifted-chat": ["./types/react-native-gifted-chat.d.ts"]
    },
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },

  "include": [
    "theme.ts",
    "nativewind-env.d.ts",
    "app/app",
    "app",
    "components",
    "constants",
    "database",
    "hooks",
    "lang",
    "modules",
    "services",
    "types",
    "utils",
    "widgets"
  ],
  "exclude": [
    "node_modules",
    "babel.config.js",
    "metro.config.js",
    "tailwind.config.js",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "gameboy",
    "training-data/.venv",
    "training-data/output/model.js",
    "utils/repCountingModel.js"
  ]
}
