{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "EAS_BUILD_PLATFORM": "simulator"
      }
    },
    "development:device": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "env": {
        "EAS_BUILD_PLATFORM": "device"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "env": {
        "EAS_BUILD_PLATFORM": "device"
      }
    },
    "production": {
      "ios": {
        "simulator": false
      },
      "env": {
        "EAS_BUILD_PLATFORM": "device"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "support@jubinganga.com",
        "ascAppId": "6761317034"
      }
    }
  }
}