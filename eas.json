{
  "cli": {
    "version": ">= 18.1.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "GRADLE_OPTS": "-Xmx4g -XX:MaxMetaspaceSize=1g"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "GRADLE_OPTS": "-Xmx4g -XX:MaxMetaspaceSize=1g"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "GRADLE_OPTS": "-Xmx4g -XX:MaxMetaspaceSize=1g"
      },
      "ios": {
        "image": "macos-sequoia-15.4-xcode-16.3"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
