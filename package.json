{
  "name": "musclog",
  "version": "2.6.7",
  "scripts": {
    "playwright-runner": "node tests/run-tests.js",
    "screenshots": "npm run build-android-web && npm run playwright-runner --",
    "screenshots-portrait": "npm run build-android-web && npm run playwright-runner --project=portrait-6.7",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "lint:eslint": "eslint .",
    "lint:eslint-fix": "eslint . --fix",
    "lint:all": "git add . && npm run lint:eslint-fix && npm run format && npm run prebuild:cross-platform && npm run typecheck",
    "prebuild:cross-platform": "node scripts/prebuild-cross-platform.js",
    "bump": "ncu -u -t minor",
    "bump-any": "ncu -u",
    "clear-cache": "rm -rf node_modules/.cache /tmp/metro-cache /tmp/haste-map-metro-* .expo .next web-build",
    "bump-app-version": "node scripts/bump.js",
    "report-modal-issue": "node scripts/report-modal-issues.js",
    "check-translations": "node scripts/check-translations.js",
    "check-locale-consistency": "node scripts/check-locale-consistency.js",
    "generate-lang": "node scripts/generateLangFile.js",
    "convert-exercise-images": "node scripts/convert-exercise-images-to-png.js",
    "postinstall": "patch-package",
    "prestart": "node scripts/sync-web-phone-frame.js",
    "start": "expo start",
    "prestart-clear": "node scripts/sync-web-phone-frame.js",
    "start-clear": "expo start --clear",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "android-device": "expo run:android --no-build-cache --device",
    "web": "node scripts/sync-web-phone-frame.js && expo start --web",
    "test": "jest --watchAll",
    "lint": "expo lint",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "prebuild": "expo prebuild --clean",
    "setup-android": "turtle setup:android",
    "build-android": "eas build -p android --profile production --clear-cache",
    "build-android-nowait": "eas build -p android --profile production --clear-cache --no-wait",
    "build-android-local": "eas build -p android --profile production --local --clear-cache",
    "build-android-web": "node scripts/sync-web-phone-frame.js && node scripts/export-web-wrapper.js",
    "submit-android": "eas submit --platform android",
    "build-android-preview": "eas build -p android --profile preview",
    "build-android-preview-local": "eas build -p android --profile preview --local",
    "build-ios": "node scripts/prepare-for-eas.js && eas build -p ios --profile production --clear-cache",
    "build-ios-nowait": "node scripts/prepare-for-eas.js && eas build -p ios --profile production --clear-cache --no-wait",
    "build-ios-dev": "node scripts/prepare-for-eas.js && eas build -p ios --profile development --clear-cache",
    "build-ios-preview": "node scripts/prepare-for-eas.js && eas build -p ios --profile preview --clear-cache",
    "build-ios-preview-nowait": "node scripts/prepare-for-eas.js && eas build -p ios --profile preview --clear-cache --no-wait",
    "submit-ios": "eas submit --platform ios",
    "prebuild-ios": "expo prebuild -p ios --clean",
    "prebuild-ios-simulator": "expo prebuild -p ios --clean && npm run patch-ios-project && cd ios && pod install",
    "prebuild-ios-device": "EXPO_IS_SIMULATOR_BUILD=false expo prebuild -p ios --clean && npm run patch-ios-project && cd ios && pod install",
    "run-ios": "expo run:ios",
    "build-and-submit-ios": "node scripts/prepare-for-eas.js && eas build --platform ios --profile production --auto-submit",
    "run-ios-device": "expo run:ios --device",
    "ios-simulator": "expo run:ios --device",
    "patch-ios-project": "node scripts/fix-ios-project.js",
    "prebuild:ios": "expo prebuild -p ios --clean && npm run patch-ios-project && cd ios && pod install"
  },
  "optionalDependencies": {
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "@babel/plugin-proposal-decorators": "7.29.0",
    "@babel/plugin-transform-class-properties": "7.28.6",
    "@babel/plugin-transform-private-methods": "7.28.6",
    "@babel/plugin-transform-private-property-in-object": "7.28.6",
    "@ericblade/quagga2": "^1.12.1",
    "@expo/vector-icons": "15.1.1",
    "@google/generative-ai": "0.24.1",
    "@gutenye/ocr-react-native": "^1.4.8",
    "@kingstinct/react-native-healthkit": "^13.4.0",
