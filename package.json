{
  "name": "musclog",
  "version": "1.0.0",
  "scripts": {
    "playwright": "node tests/run-tests.js",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "lint:eslint": "eslint .",
    "lint:eslint-fix": "eslint . --fix",
    "bump": "ncu -u -t minor",
    "bump-any": "ncu -u",
    "clear-cache": "rm -rf /tmp/metro-cache /tmp/haste-map-metro-* .expo .next web-build",
    "bump-app-version": "node scripts/bump.js",
    "start": "expo start",
    "start-clear": "expo start --clear",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "android-device": "expo run:android --no-build-cache --device",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "lint": "expo lint",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "prebuild": "expo prebuild --clean",
    "setup-android": "turtle setup:android",
    "build-android": "eas build -p android",
    "build-android-local": "eas build -p android --local",
    "build-android-web": "expo export --platform web",
    "submit-android": "eas submit --platform android",
    "build-android-preview": "eas build -p android --profile preview",
    "build-android-preview-local": "eas build -p android --profile preview --local"
  },
  "dependencies": {
    "@babel/plugin-proposal-decorators": "^7.28.6",
    "@babel/plugin-transform-class-properties": "^7.28.6",
    "@babel/plugin-transform-private-methods": "^7.28.6",
    "@babel/plugin-transform-private-property-in-object": "^7.28.6",
    "@ericblade/quagga2": "^1.12.1",
    "@expo/vector-icons": "^15.0.3",
    "@google/generative-ai": "^0.24.1",
    "@nozbe/watermelondb": "^0.28.0",
    "@react-native-community/slider": "5.0.1",
    "@react-native-masked-view/masked-view": "^0.3.2",
    "@sentry/react-native": "~7.2.0",
    "@shopify/react-native-skia": "2.2.12",
    "@zxing/library": "^0.21.3",
    "buffer": "^6.0.3",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "expo": "^54.0.31",
    "expo-auth-session": "~7.0.10",
    "expo-background-task": "~1.0.10",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-calendar": "~15.0.8",
