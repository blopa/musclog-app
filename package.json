{
  "name": "musclog",
  "version": "2.1.0",
  "scripts": {
    "playwright": "node tests/run-tests.js",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "lint:eslint": "eslint .",
    "lint:eslint-fix": "eslint . --fix",
    "bump": "ncu -u -t minor",
    "bump-any": "ncu -u",
    "clear-cache": "rm -rf node_modules/.cache /tmp/metro-cache /tmp/haste-map-metro-* .expo .next web-build",
    "bump-app-version": "node scripts/bump.js",
    "check-translations": "node scripts/check-translations.js",
    "start": "expo start",
    "start-clear": "expo start --clear",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "android-device": "expo run:android --no-build-cache --device",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "lint": "expo lint",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "prebuild": "expo prebuild --clean",
    "setup-android": "turtle setup:android",
    "build-android": "eas build -p android",
    "build-android-local": "eas build -p android --local",
    "build-android-web": "expo export --platform web",
    "submit-android": "eas submit --platform android",
    "build-android-preview": "eas build -p android --profile preview",
    "build-android-preview-local": "eas build -p android --profile preview --local"
  },
  "dependencies": {
    "@babel/plugin-proposal-decorators": "7.29.0",
    "@babel/plugin-transform-class-properties": "7.28.6",
