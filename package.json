    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@babel/core": "^7.28.6",
    "@types/isomorphic-fetch": "^0.0.39",
    "@types/react": "~19.1.10",
    "eslint": "^9.39.2",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "npm-check-updates": "^19.3.1",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3"
  },
  "main": "expo-router/entry",
  "private": false,
  "license": "CC-BY-NC-ND-4.0",
  "expo": {
    "doctor": {
